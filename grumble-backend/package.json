{
  "name": "grumble-backend",
  "private": true,
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "achievement:test-streak": "node scripts/testAchievementStreak.js",
    "sync-osm": "node scripts/syncOSM.js",
    "admin:create": "node scripts/createAdmin.js",
    "telegram:helper": "node scripts/telegramBotHelper.js",
    "migrate:supabase": "node scripts/runMigrations.js",
    "migrate:001": "psql -U postgres -d grumble -f migrations/001_create_food_places.sql",
    "migrate:002": "psql -U postgres -d grumble -f migrations/002_create_users.sql",
    "migrate:003": "psql -U postgres -d grumble -f migrations/003_add_telegram_fields.sql",
    "migrate:004": "psql -U postgres -d grumble -f migrations/004_create_admin_tables.sql",
    "migrate:005": "psql -U postgres -d grumble -f migrations/005_create_saves.sql",
    "migrate:006": "psql -U postgres -d grumble -f migrations/006_add_food_place_enrichment_fields.sql",
    "migrate:007": "psql -U postgres -d grumble -f migrations/007_consolidated_chat_through_support.sql",
    "migrate:008": "psql -U postgres -d grumble -f migrations/008_create_chat_tables.sql",
    "migrate:009": "psql -U postgres -d grumble -f migrations/009_add_spin_wheel_spins.sql",
    "migrate:010": "psql -U postgres -d grumble -f migrations/010_create_buildings_table.sql",
    "migrate:011": "psql -U postgres -d grumble -f migrations/011_add_user_avatar.sql",
    "migrate:012": "psql -U postgres -d grumble -f migrations/012_create_user_preferences.sql",
    "migrate:013": "psql -U postgres -d grumble -f migrations/013_add_postal_code_to_posts.sql",
    "migrate:014": "psql -U postgres -d grumble -f migrations/014_fix_polls_and_spinwheel.sql",
    "migrate:015": "psql -U postgres -d grumble -f migrations/015_add_chat_message_replies.sql",
    "migrate:016": "psql -U postgres -d grumble -f migrations/016_seed_faqs.sql",
    "migrate:017": "psql -U postgres -d grumble -f migrations/017_achievements_and_avatars.sql",
    "migrate:018": "psql -U postgres -d grumble -f migrations/018_create_support_reports.sql",
    "migrate:019": "psql -U postgres -d grumble -f migrations/019_create_notifications.sql",
    "migrate:all": "npm run migrate:001 && npm run migrate:002 && npm run migrate:003 && npm run migrate:004 && npm run migrate:005 && npm run migrate:006 && npm run migrate:007 && npm run migrate:008 && npm run migrate:009 && npm run migrate:010 && npm run migrate:011 && npm run migrate:012 && npm run migrate:013 && npm run migrate:014 && npm run migrate:015 && npm run migrate:016 && npm run migrate:017 && npm run migrate:018 && npm run migrate:019"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.3",
    "axios": "^1.13.5",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pg": "^8.18.0",
    "socket.io": "^4.8.3",
    "supabase-js": "^0.0.1-security"
  },
  "devDependencies": {
    "@flydotio/dockerfile": "^0.7.10"
  }
}
